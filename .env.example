# Copy this file to .env and fill in your values.
# .env is NOT committed to source control.

# Optional: OpenAI API key for advanced natural-language responses.
# Leave blank to use the built-in keyword-based command handling only.
OPENAI_API_KEY=

# OpenAI model to use (default: gpt-3.5-turbo)
OPENAI_MODEL=gpt-3.5-turbo

# Assistant name shown in responses
ASSISTANT_NAME=Jarvis

# Wake word for voice mode
WAKE_WORD=jarvis

# Text-to-speech rate (words per minute, default 175)
TTS_RATE=175

# TTS volume (0.0 – 1.0)
TTS_VOLUME=1.0

# Speech recognition timeout in seconds
STT_TIMEOUT=5

# Maximum seconds to wait for a phrase
STT_PHRASE_LIMIT=10

# Maximum conversation history entries to keep
MAX_HISTORY=100
